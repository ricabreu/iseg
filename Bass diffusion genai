#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Bass Diffusion Model for Generative AI Research
================================================

Reproducible analysis code for the paper:

    "Modelling the Diffusion of Generative AI Research: A Bass Framework with Bibliometric Calibration and Monte Carlo Analysis"
    Ricardo Abreu, AMMS 2026.

This script reproduces every quantitative result and figure in the paper:

  1. Parses the Scopus RIS export and builds the annual publication trajectory.
  2. Calibrates the Bass diffusion model (market potential m, innovation
     coefficient p, imitation coefficient q) by nonlinear least squares.
  3. Forecasts the diffusion trajectory and decomposes it into innovation and
     imitation components.
  4. Quantifies parameter uncertainty via a 10,000-run Monte Carlo simulation.
  5. Produces a parameter-space sensitivity analysis (peak year and fit quality).
  6. Renders the three figures used in the paper.

------------------------------------------------------------------------------
Corpus
------------------------------------------------------------------------------
Scopus query (executed May 2026, 517 records = 415 journal + 102 conference):

    TITLE-ABS-KEY ( ( "generative AI" OR "generative artificial intelligence"
      OR "large language model*" OR LLM* OR "foundation model*" OR ChatGPT
      OR Gemini OR Claude )
    AND ( "technology adoption" OR "organizational adoption" OR "firm adoption"
      OR "business adoption" OR "innovation diffusion" OR "technology diffusion" ) )
    AND ( LIMIT-TO ( LANGUAGE , "English" ) )
    AND ( LIMIT-TO ( SUBJAREA , "SOCI" ) OR LIMIT-TO ( SUBJAREA , "BUSI" )
      OR LIMIT-TO ( SUBJAREA , "COMP" ) OR LIMIT-TO ( SUBJAREA , "PSYC" )
      OR LIMIT-TO ( SUBJAREA , "ENGI" ) OR LIMIT-TO ( SUBJAREA , "DECI" ) )
    AND ( LIMIT-TO ( DOCTYPE , "ar" ) OR LIMIT-TO ( DOCTYPE , "cp" ) )

------------------------------------------------------------------------------
Usage
------------------------------------------------------------------------------
    python bass_diffusion_genai.py --ris Paper2_biblio_517.ris --outdir figures

If --ris is omitted, the script falls back to the published annual counts so
that the calibration and figures can be reproduced without the raw export.

Dependencies: numpy, scipy, matplotlib  (pip install numpy scipy matplotlib)
License: MIT
------------------------------------------------------------------------------
"""

import argparse
import os
import re
from collections import Counter

import numpy as np
from scipy.optimize import curve_fit

import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt


# =============================================================================
# 1. DATA: parse the Scopus RIS export into an annual publication trajectory
# =============================================================================

# Published fallback counts (used if no RIS file is supplied).
# Raw observed counts; 2026 is a partial year (export taken mid-May 2026).
PUBLISHED_ANNUAL = {2023: 24, 2024: 88, 2025: 249, 2026: 155}
PARTIAL_YEAR = 2026
ELAPSED_FRACTION = 5.0 / 12.0  # ~five months of 2026 observed at export time


def parse_ris(path):
    """Return {year: count} of records per publication year from a RIS file."""
    with open(path, "r", encoding="utf-8", errors="replace") as fh:
        content = fh.read()

    # Records are separated by the ER (end-of-reference) tag.
    records = [r for r in content.strip().split("\nER  -") if r.strip()]

    years = []
    for rec in records:
        m = re.search(r"^PY  - (\d{4})", rec, re.MULTILINE)
        if m:
            years.append(int(m.group(1)))

    counts = Counter(years)
    print(f"[data] parsed {len(records)} records from {os.path.basename(path)}")
    return dict(counts)


def build_trajectory(annual_counts):
    """
    Build the calibration arrays from raw annual counts.

    The single pre-2023 record (a 2022 article) is folded into the baseline,
    so the calibration window effectively spans 2023..2026. The partial 2026
    count is annualised by linear extrapolation from the elapsed fraction.

    Returns
    -------
    years      : np.ndarray of calendar years used for calibration
    t          : np.ndarray of integer time steps (1 = 2023, ...)
    annual_adj : np.ndarray of annualised annual counts
    """
    years = np.array(sorted(y for y in annual_counts if y >= 2023))
    raw = np.array([annual_counts[y] for y in years], dtype=float)

    annual_adj = raw.copy()
    if PARTIAL_YEAR in years:
        idx = int(np.where(years == PARTIAL_YEAR)[0][0])
        projected = round(annual_counts[PARTIAL_YEAR] / ELAPSED_FRACTION)
        annual_adj[idx] = projected
        print(f"[data] {PARTIAL_YEAR} annualised: "
              f"{annual_counts[PARTIAL_YEAR]} -> {projected}")

    t = np.arange(1, len(years) + 1)
    print(f"[data] calibration years: {years.tolist()}")
    print(f"[data] annualised counts: {annual_adj.astype(int).tolist()}")
    return years, t, annual_adj


# =============================================================================
# 2. THE BASS MODEL
# =============================================================================

def bass_F(t, p, q):
    """Cumulative adoption fraction F(t) (closed-form Bass solution)."""
    return (1.0 - np.exp(-(p + q) * t)) / (1.0 + (q / p) * np.exp(-(p + q) * t))


def bass_annual_flow(t, N, p, q):
    """
    Annual number of new adopters at integer time steps:
        S(t) = N * [F(t) - F(t-1)]
    """
    t = np.atleast_1d(t).astype(float)
    return np.array([N * (bass_F(ti, p, q) - bass_F(ti - 1.0, p, q)) for ti in t])


def peak_time(p, q):
    """Time of peak adoption (years after the baseline), t* = ln(q/p)/(p+q)."""
    return np.log(q / p) / (p + q)


def crossover_time(p, q):
    """Time at which the imitation term overtakes the innovation term."""
    return np.log(1.0 + p / q) / (p + q)


# =============================================================================
# 3. CALIBRATION (nonlinear least squares)
# =============================================================================

def calibrate(t, annual_adj):
    """Fit (N, p, q) to the annualised annual flow. Returns dict of results."""
    popt, pcov = curve_fit(
        bass_annual_flow, t, annual_adj,
        p0=[2000.0, 0.02, 0.5],
        bounds=([100.0, 1e-3, 1e-2], [1e5, 0.3, 3.0]),
        maxfev=20000,
    )
    N, p, q = popt
    perr = np.sqrt(np.diag(pcov))

    fitted = bass_annual_flow(t, N, p, q)
    ss_res = np.sum((annual_adj - fitted) ** 2)
    ss_tot = np.sum((annual_adj - np.mean(annual_adj)) ** 2)
    r2 = 1.0 - ss_res / ss_tot

    res = dict(N=N, p=p, q=q, N_err=perr[0], p_err=perr[1], q_err=perr[2],
               r2=r2, fitted=fitted)

    print("\n=== Bass calibration ===")
    print(f"  N (market potential) = {N:8.1f}  +/- {perr[0]:.1f}")
    print(f"  p (innovation)       = {p:8.4f}  +/- {perr[1]:.4f}")
    print(f"  q (imitation)        = {q:8.4f}  +/- {perr[2]:.4f}")
    print(f"  q/p (regime)         = {q / p:8.1f}")
    print(f"  peak year            = {2022 + peak_time(p, q):8.2f}")
    print(f"  R^2                  = {r2:8.4f}")
    return res


# =============================================================================
# 4. MONTE CARLO uncertainty propagation
# =============================================================================

def monte_carlo(t_all, N, p, q, n_runs=10000, seed=42):
    """
    Propagate parameter uncertainty by sampling (p, q, N) from uniform
    neighbourhoods around the fitted values and recomputing the trajectory.

    Returns a dict of percentile bands (5/25/50/75/95) for the annual flow.
    """
    rng = np.random.default_rng(seed)
    ps = rng.uniform(p * 0.5, p * 1.5, n_runs)
    qs = rng.uniform(q * 0.7, q * 1.3, n_runs)
    Ns = rng.uniform(N * 0.7, N * 1.3, n_runs)

    flows = np.array([bass_annual_flow(t_all, Ns[i], ps[i], qs[i])
                      for i in range(n_runs)])
    flows = flows[~np.any(np.isnan(flows), axis=1)]
    print(f"\n[mc] valid runs: {flows.shape[0]}/{n_runs}")

    return {pc: np.percentile(flows, pc, axis=0)
            for pc in (5, 25, 50, 75, 95)}


# =============================================================================
# 5. FIGURES
# =============================================================================

COL = {"obs": "#1a1a2e", "fit": "#e94560", "band": "#4a90d9"}


def fig_forecast(years_obs, ann_obs, cum_obs, years_all, ann_proj, cum_proj,
                 bands, res, outpath):
    """Figure 1: annual flow + cumulative S-curve with Monte Carlo bands."""
    p, q, N = res["p"], res["q"], res["N"]
    p5, p25, p50, p75, p95 = (bands[k] for k in (5, 25, 50, 75, 95))

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))
    fig.patch.set_facecolor("#FAFAFA")
    for ax in (ax1, ax2):
        ax.set_facecolor("#F5F7FA")

    # Left: annual flow
    ax1.fill_between(years_all, p5, p95, alpha=.18, color=COL["band"], label="90% CI")
    ax1.fill_between(years_all, p25, p75, alpha=.30, color=COL["band"], label="50% CI")
    ax1.plot(years_all, p50, "--", color=COL["band"], lw=1.5, alpha=.7, label="MC median")
    ax1.plot(years_all, ann_proj, "-", color=COL["fit"], lw=2.5, label="Bass fit", zorder=5)
    ax1.scatter(years_obs, ann_obs, s=90, color=COL["obs"], zorder=10, label="Observed")
    pk = 2022 + peak_time(p, q)
    ax1.axvline(pk, color=COL["fit"], lw=1.2, ls=":", alpha=.8)
    ax1.text(pk + .08, max(ann_proj) * .92, f"Peak \u2248 {pk:.1f}", fontsize=9, color=COL["fit"])
    ax1.set_title("Annual Adoption Flow\n(Bass Model + Monte Carlo Bands)",
                  fontsize=11, fontweight="bold")
    ax1.set_xlabel("Year"); ax1.set_ylabel("Publications per Year")
    ax1.legend(fontsize=8.5); ax1.set_xlim(2022.5, years_all.max() + .5)
    ax1.grid(True, alpha=.3, ls=":"); ax1.spines[["top", "right"]].set_visible(False)

    # Right: cumulative S-curve
    cb = {k: np.cumsum(v) for k, v in bands.items()}
    ax2.fill_between(years_all, cb[5], cb[95], alpha=.18, color=COL["band"], label="90% CI")
    ax2.fill_between(years_all, cb[25], cb[75], alpha=.30, color=COL["band"], label="50% CI")
    ax2.plot(years_all, cb[50], "--", color=COL["band"], lw=1.5, alpha=.7, label="MC median")
    ax2.plot(years_all, cum_proj, "-", color=COL["fit"], lw=2.5, label="Bass fit", zorder=5)
    ax2.scatter(years_obs, cum_obs, s=90, color=COL["obs"], zorder=10, label="Observed")
    ax2.axhline(N, color="#888", lw=1.2, ls="--", alpha=.7)
    ax2.text(years_all.min(), N + 15, f"N = {N:.0f}", fontsize=8.5, color="#555")
    ax2.set_title("Cumulative Adoption (S-Curve)\n(Bass Model + Monte Carlo Bands)",
                  fontsize=11, fontweight="bold")
    ax2.set_xlabel("Year"); ax2.set_ylabel("Cumulative Publications")
    ax2.legend(fontsize=8.5); ax2.set_xlim(2022.5, years_all.max() + .5)
    ax2.grid(True, alpha=.3, ls=":"); ax2.spines[["top", "right"]].set_visible(False)

    fig.text(0.5, 0.01,
             f"p = {p:.4f}  |  q = {q:.4f}  |  q/p = {q / p:.0f}  |  "
             f"N = {N:.0f}  |  R\u00b2 = {res['r2']:.3f}",
             ha="center", fontsize=9.5,
             bbox=dict(boxstyle="round,pad=0.4", facecolor="#e8f0fe",
                       edgecolor="#4a90d9", alpha=.9))
    plt.tight_layout(rect=[0, .06, 1, 1])
    fig.savefig(outpath, dpi=180, bbox_inches="tight", facecolor="#FAFAFA")
    plt.close(fig)
    print(f"[fig] wrote {outpath}")


def fig_decomposition(years_obs, ann_obs, res, outpath):
    """Figure 2: innovation vs imitation decomposition of the adoption rate."""
    p, q, N = res["p"], res["q"], res["N"]
    tf = np.linspace(0.01, 9, 500)
    yf = 2022 + tf
    Ft = bass_F(tf, p, q)
    innov = N * p * (1 - Ft)
    imit = N * q * Ft * (1 - Ft)
    total = innov + imit

    fig, ax = plt.subplots(figsize=(12, 5.5))
    fig.patch.set_facecolor("#FAFAFA"); ax.set_facecolor("#F5F7FA")
    ax.fill_between(yf, 0, innov, alpha=.5, color="#4CAF50",
                    label="Innovation effect  p\u00b7(1\u2212F)\u00b7N")
    ax.fill_between(yf, innov, total, alpha=.5, color="#e94560",
                    label="Imitation effect  q\u00b7F\u00b7(1\u2212F)\u00b7N")
    ax.plot(yf, total, "-", color="#1a1a2e", lw=2, label="Total adoption flow")
    ax.scatter(years_obs, ann_obs, s=100, color="#1a1a2e", zorder=10,
               marker="D", label="Observed data")
    cx = 2022 + crossover_time(p, q)
    ax.axvline(cx, color="#888", lw=1.2, ls="--", alpha=.7)
    ax.text(cx + .05, max(total) * .72, f"Crossover\n\u2248 {cx:.1f}",
            fontsize=8.5, color="#555")
    ax.set_title("Bass Model Decomposition: Innovation vs Imitation Effects\n"
                 "(Generative AI Academic Diffusion)",
                 fontsize=11, fontweight="bold")
    ax.set_xlabel("Year"); ax.set_ylabel("Annual Publications")
    ax.legend(fontsize=9); ax.set_xlim(2022.5, yf.max() + .5)
    ax.grid(True, alpha=.3, ls=":"); ax.spines[["top", "right"]].set_visible(False)
    plt.tight_layout()
    fig.savefig(outpath, dpi=180, bbox_inches="tight", facecolor="#FAFAFA")
    plt.close(fig)
    print(f"[fig] wrote {outpath}")


def fig_parameter_space(res, anchor_t3, anchor_t4, outpath):
    """Figure 3: parameter-space response surfaces (peak year and fit quality)."""
    p, q, N = res["p"], res["q"], res["N"]
    pg = np.linspace(0.003, 0.025, 80)
    qg = np.linspace(0.6, 2.0, 80)
    PP, QQ = np.meshgrid(pg, qg)

    peak = 2022 + np.log(QQ / PP) / (PP + QQ)
    t3 = N * (bass_F(3, PP, QQ) - bass_F(2, PP, QQ))
    t4 = N * (bass_F(4, PP, QQ) - bass_F(3, PP, QQ))
    sse = (t3 - anchor_t3) ** 2 + (t4 - anchor_t4) ** 2

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5.5))
    fig.patch.set_facecolor("#FAFAFA")

    im1 = ax1.contourf(pg, qg, peak, levels=20, cmap="RdYlGn_r")
    ax1.contour(pg, qg, peak, levels=[2025, 2026, 2027], colors="white",
                linewidths=1.2, alpha=.8)
    ax1.scatter([p], [q], s=150, marker="*", color="white", zorder=10,
                label=f"Fitted (p={p:.4f}, q={q:.4f})")
    plt.colorbar(im1, ax=ax1, label="Peak adoption year")
    ax1.set_xlabel("Innovation coefficient (p)")
    ax1.set_ylabel("Imitation coefficient (q)")
    ax1.set_title("Parameter Space: Peak Adoption Year", fontsize=11, fontweight="bold")
    ax1.legend(fontsize=8.5, loc="upper right")
    ax1.grid(True, alpha=.2); ax1.spines[["top", "right"]].set_visible(False)

    im2 = ax2.contourf(pg, qg, np.log1p(sse), levels=25, cmap="YlOrRd")
    ax2.scatter([p], [q], s=150, marker="*", color="white", zorder=10, label="Optimal fit")
    plt.colorbar(im2, ax=ax2, label="log(1 + SSE)")
    ax2.set_xlabel("Innovation coefficient (p)")
    ax2.set_ylabel("Imitation coefficient (q)")
    ax2.set_title("Parameter Space: Fit Quality (SSE)", fontsize=11, fontweight="bold")
    ax2.legend(fontsize=8.5, loc="upper right")
    ax2.grid(True, alpha=.2); ax2.spines[["top", "right"]].set_visible(False)
    plt.tight_layout()
    fig.savefig(outpath, dpi=180, bbox_inches="tight", facecolor="#FAFAFA")
    plt.close(fig)
    print(f"[fig] wrote {outpath}")


# =============================================================================
# MAIN
# =============================================================================

def main():
    ap = argparse.ArgumentParser(description="Bass diffusion analysis of GenAI adoption.")
    ap.add_argument("--ris", default=None,
                    help="Path to the Scopus RIS export. If omitted, uses published counts.")
    ap.add_argument("--outdir", default="figures", help="Directory for output figures.")
    ap.add_argument("--horizon", type=int, default=2031,
                    help="Last year of the forecast (default 2031).")
    args = ap.parse_args()

    os.makedirs(args.outdir, exist_ok=True)

    # --- 1. Data ---
    if args.ris and os.path.exists(args.ris):
        annual_counts = parse_ris(args.ris)
    else:
        if args.ris:
            print(f"[warn] RIS file '{args.ris}' not found; using published counts.")
        else:
            print("[data] no RIS supplied; using published annual counts.")
        annual_counts = dict(PUBLISHED_ANNUAL)

    years_obs, t_obs, annual_adj = build_trajectory(annual_counts)
    cum_obs = np.cumsum(annual_adj)

    # --- 2-3. Calibrate ---
    res = calibrate(t_obs, annual_adj)

    # --- Forecast horizon ---
    n_years = args.horizon - 2022
    t_all = np.arange(1, n_years + 1)
    years_all = 2022 + t_all
    ann_proj = bass_annual_flow(t_all, res["N"], res["p"], res["q"])
    cum_proj = np.cumsum(ann_proj)

    # --- 4. Monte Carlo ---
    bands = monte_carlo(t_all, res["N"], res["p"], res["q"])

    # --- 5. Figures ---
    fig_forecast(years_obs, annual_adj, cum_obs, years_all, ann_proj, cum_proj,
                 bands, res, os.path.join(args.outdir, "fig_bass_forecast.png"))
    fig_decomposition(years_obs, annual_adj, res,
                      os.path.join(args.outdir, "fig_decomposition.png"))
    # SSE anchors are the observed (annualised) 2025 and 2026 counts.
    anchor_t3 = annual_adj[t_obs == 3][0] if np.any(t_obs == 3) else 249
    anchor_t4 = annual_adj[t_obs == 4][0] if np.any(t_obs == 4) else 372
    fig_parameter_space(res, anchor_t3, anchor_t4,
                        os.path.join(args.outdir, "fig_param_space.png"))

    print("\n[done] all results and figures reproduced.")


if __name__ == "__main__":
    main()
